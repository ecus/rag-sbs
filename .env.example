# =============================================================================
# RAG SBS — Variables de entorno (ejemplo)
# =============================================================================
# Copia este archivo como .env y ajusta los valores. NUNCA commitear .env real.

# ----- App -----
APP_ENV=local                          # local | staging | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
APP_VERSION=0.1.0

# ----- Database (pgvector) -----
# Dentro de podman-compose, el host es "postgres". Desde tu Mac directamente: localhost.
DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/ragdb

# ----- LLM Provider -----
# ollama | vertex_flash | vertex_pro
LLM_PROVIDER=ollama

# Ollama (corre en el host, no en container — usar host.containers.internal en Podman)
OLLAMA_BASE_URL=http://host.containers.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# Vertex AI (se completa en Bloque C Sprint 3)
GOOGLE_API_KEY=                        # Para AI Studio (gratis)
GOOGLE_CLOUD_PROJECT=                  # Para Vertex AI productivo
VERTEX_LOCATION=us-central1
VERTEX_FLASH_MODEL=gemini-1.5-flash-002
VERTEX_PRO_MODEL=gemini-1.5-pro-002
VERTEX_EMBED_MODEL=text-embedding-004

# ----- RAG Pipeline -----
CHUNK_SIZE=768
CHUNK_OVERLAP=96
TOP_K=5
SIMILARITY_THRESHOLD=0.78

# ----- Reranker -----
# llm           — default local (sin deps extra, usa el LLMProvider)
# cross_encoder — Cloud / GKE (requiere sentence-transformers + torch, ~3GB)
# cohere        — Cloud enterprise (requiere COHERE_API_KEY)
RERANKER_BACKEND=llm
COHERE_API_KEY=
CROSS_ENCODER_MODEL=BAAI/bge-reranker-base

# ----- Cache (Redis) -----
REDIS_URL=redis://redis:6379/0
SEMANTIC_CACHE_TTL_SEC=86400           # 24h
SEMANTIC_CACHE_SIM=0.95

# ----- Auth (Sprint 2) -----
JWT_SECRET=change-me-in-real-deployments-please-use-256-bits
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=8
